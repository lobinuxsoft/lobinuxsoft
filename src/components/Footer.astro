---
import { type Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import { SOCIAL } from '@/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="mono footer__mark">~/matias</span>
      <p class="footer__copy">© {year} Matias Galarza Fernandez. {t('footer.rights')}</p>
    </div>
    <ul role="list" class="footer__links">
      <li><a href={`mailto:${SOCIAL.email}`}>Email</a></li>
      <li><a href={SOCIAL.github} target="_blank" rel="noopener">GitHub</a></li>
      <li><a href={SOCIAL.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>
    </ul>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding-block: var(--space-xl);
    margin-top: var(--space-2xl);
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
    justify-content: space-between;
  }
  .footer__mark {
    color: var(--accent);
    font-size: var(--step--1);
  }
  .footer__copy {
    color: var(--text-subtle);
    font-size: var(--step--1);
    margin-top: var(--space-2xs);
  }
  .footer__links {
    display: flex;
    gap: var(--space-lg);
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .footer__links a {
    color: var(--text-muted);
    transition: color var(--dur) var(--ease);
  }
  .footer__links a:hover {
    color: var(--accent);
  }
</style>
