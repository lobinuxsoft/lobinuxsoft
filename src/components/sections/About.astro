---
import { type Lang } from '@/i18n/ui';
import { useTranslations, pick } from '@/i18n/utils';
import { profile } from '@/data/profile';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const stats = [
  { value: '9+', label: { en: 'years shipping', es: 'años publicando' } },
  { value: '5', label: { en: 'edu titles shipped', es: 'títulos edu publicados' } },
  { value: '4', label: { en: 'open-source tools', es: 'herramientas open-source' } },
  { value: 'VR', label: { en: 'multiplayer @ 3dar', es: 'multiplayer @ 3dar' } },
];
---

<section class="section about" id="about" aria-labelledby="about-title">
  <div class="container about__grid">
    <div class="about__head" data-reveal>
      <p class="eyebrow">{t('section.about')}</p>
      <h2 class="section-title" id="about-title">
        {lang === 'es' ? 'Del concepto al producto, con rigor de industria.' : 'From concept to product, with industry rigor.'}
      </h2>
    </div>

    <div class="about__body">
      <p class="lead" data-reveal>{pick(profile.summary, lang)}</p>

      <ul role="list" class="about__stats" data-reveal style="--reveal-delay: 120ms">
        {
          stats.map((s) => (
            <li class="stat">
              <span class="stat__value mono">{s.value}</span>
              <span class="stat__label">{pick(s.label, lang)}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }
  @media (min-width: 60rem) {
    .about__grid {
      grid-template-columns: 0.8fr 1.2fr;
      gap: var(--space-3xl);
    }
    .about__head {
      position: sticky;
      top: 6rem;
      align-self: start;
    }
    .section-title {
      margin-bottom: 0;
    }
  }
  .about__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    margin: 0;
    margin-top: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--border);
  }
  @media (min-width: 40rem) {
    .about__stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  .stat__value {
    font-size: var(--step-3);
    font-weight: 500;
    color: var(--accent);
    line-height: 1;
  }
  .stat__label {
    font-size: var(--step--1);
    color: var(--text-subtle);
  }
</style>
